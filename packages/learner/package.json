{
  "name": "@openclawbrain/learner",
  "version": "0.1.0",
  "description": "Candidate-pack assembly and learner-side artifact materialization for OpenClawBrain.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Jonathan Gu <jonathangu@gmail.com>",
  "keywords": [
    "openclawbrain",
    "learner",
    "packs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathangu/openclawbrain.git",
    "directory": "packages/learner"
  },
  "homepage": "https://github.com/jonathangu/openclawbrain/tree/main/packages/learner#readme",
  "bugs": {
    "url": "https://github.com/jonathangu/openclawbrain/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "prepack": "pnpm run build",
    "test": "node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@openclawbrain/contracts": "workspace:^",
    "@openclawbrain/pack-format": "workspace:^"
  }
}
