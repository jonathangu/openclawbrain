{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawbrain.dev/contracts/runtime_compile/v1/response.schema.json",
  "title": "runtime_compile.v1 response",
  "type": "object",
  "required": [
    "contract",
    "packId",
    "selectedContext",
    "diagnostics"
  ],
  "properties": {
    "contract": {
      "const": "runtime_compile.v1"
    },
    "packId": {
      "type": "string",
      "minLength": 1
    },
    "selectedContext": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "tokenCount": {
            "type": "integer",
            "minimum": 0
          },
          "compactedFrom": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "modeRequested",
        "modeEffective",
        "usedLearnedRouteFn",
        "routerIdentity",
        "candidateCount",
        "selectedCount",
        "selectedCharCount",
        "selectedTokenCount",
        "selectionStrategy",
        "selectionDigest",
        "compactionMode",
        "compactionApplied",
        "notes"
      ],
      "properties": {
        "modeRequested": {
          "enum": [
            "heuristic",
            "learned"
          ]
        },
        "modeEffective": {
          "enum": [
            "heuristic",
            "learned"
          ]
        },
        "usedLearnedRouteFn": {
          "type": "boolean"
        },
        "routerIdentity": {
          "type": [
            "string",
            "null"
          ]
        },
        "candidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "selectedCount": {
          "type": "integer",
          "minimum": 0
        },
        "selectedCharCount": {
          "type": "integer",
          "minimum": 0
        },
        "selectedTokenCount": {
          "type": "integer",
          "minimum": 0
        },
        "selectionStrategy": {
          "const": "pack_keyword_overlap_v1"
        },
        "selectionDigest": {
          "type": "string",
          "minLength": 1
        },
        "compactionMode": {
          "enum": [
            "none",
            "native"
          ]
        },
        "compactionApplied": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
