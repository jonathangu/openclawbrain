{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawbrain.dev/contracts/runtime_compile/v1/request.schema.json",
  "title": "runtime_compile.v1 request",
  "type": "object",
  "required": [
    "contract",
    "agentId",
    "userMessage",
    "maxContextBlocks",
    "modeRequested"
  ],
  "properties": {
    "contract": {
      "const": "runtime_compile.v1"
    },
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "userMessage": {
      "type": "string",
      "minLength": 1
    },
    "maxContextBlocks": {
      "type": "integer",
      "minimum": 0
    },
    "maxContextChars": {
      "type": "integer",
      "minimum": 0
    },
    "modeRequested": {
      "enum": [
        "heuristic",
        "learned"
      ]
    },
    "activePackId": {
      "type": "string"
    },
    "runtimeHints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compactionMode": {
      "enum": [
        "none",
        "native"
      ]
    }
  },
  "additionalProperties": false
}
