{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclawbrain.dev/contracts/artifact_manifest/v1/manifest.schema.json",
  "title": "artifact_manifest.v1 manifest",
  "type": "object",
  "required": [
    "contract",
    "packId",
    "immutable",
    "routePolicy",
    "runtimeAssets",
    "payloadChecksums",
    "modelFingerprints",
    "provenance",
    "graphDynamics"
  ],
  "properties": {
    "contract": {
      "const": "artifact_manifest.v1"
    },
    "packId": {
      "type": "string",
      "minLength": 1
    },
    "immutable": {
      "const": true
    },
    "routePolicy": {
      "enum": [
        "heuristic_allowed",
        "requires_learned_routing"
      ]
    },
    "runtimeAssets": {
      "type": "object",
      "required": [
        "graphPath",
        "vectorPath",
        "router"
      ],
      "properties": {
        "graphPath": {
          "type": "string",
          "minLength": 1
        },
        "vectorPath": {
          "type": "string",
          "minLength": 1
        },
        "router": {
          "type": "object",
          "required": [
            "kind",
            "identity",
            "artifactPath"
          ],
          "properties": {
            "kind": {
              "enum": [
                "none",
                "stub",
                "artifact"
              ]
            },
            "identity": {
              "type": [
                "string",
                "null"
              ]
            },
            "artifactPath": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "payloadChecksums": {
      "type": "object",
      "required": [
        "graph",
        "vector",
        "router"
      ],
      "properties": {
        "graph": {
          "type": "string",
          "minLength": 1
        },
        "vector": {
          "type": "string",
          "minLength": 1
        },
        "router": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "modelFingerprints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object"
    },
    "graphDynamics": {
      "type": "object",
      "required": [
        "hebbian",
        "decay",
        "structuralOps"
      ],
      "properties": {
        "hebbian": {
          "type": "object"
        },
        "decay": {
          "type": "object"
        },
        "structuralOps": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
