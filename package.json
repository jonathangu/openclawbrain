{
  "name": "openclawbrain-workspace",
  "version": "0.1.1",
  "private": true,
  "description": "TypeScript-first OpenClawBrain workspace for deterministic pack-backed context selection and native structural compaction.",
  "license": "Apache-2.0",
  "author": "Jonathan Gu <jonathangu@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathangu/openclawbrain.git"
  },
  "homepage": "https://github.com/jonathangu/openclawbrain#readme",
  "bugs": {
    "url": "https://github.com/jonathangu/openclawbrain/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "openclawbrain",
    "typescript",
    "context-engineering",
    "context-compaction",
    "pack-backed-memory"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && tsc -b --clean tsconfig.build.json && rm -rf .release",
    "check": "pnpm guard:merge-markers && pnpm test && pnpm lifecycle:smoke:built && pnpm observability:smoke:built",
    "lifecycle:smoke": "pnpm build && node ./scripts/lifecycle-smoke.mjs",
    "lifecycle:smoke:built": "node ./scripts/lifecycle-smoke.mjs",
    "observability:smoke": "pnpm build && node ./scripts/observability-smoke.mjs",
    "observability:smoke:built": "node ./scripts/observability-smoke.mjs",
    "release:check": "pnpm clean && pnpm check && pnpm release:pack",
    "release:pack": "ROOT_DIR=$(pwd) && mkdir -p \"$ROOT_DIR/.release\" && pnpm -r --filter \"@openclawbrain/*\" pack --pack-destination \"$ROOT_DIR/.release\"",
    "release:publish": "pnpm -r --filter \"@openclawbrain/*\" publish --access public --no-git-checks",
    "release:publish:dry-run": "pnpm -r --filter \"@openclawbrain/*\" publish --access public --no-git-checks --dry-run",
    "release:publish:provenance": "pnpm -r --filter \"@openclawbrain/*\" publish --access public --no-git-checks --provenance",
    "typecheck": "tsc -b --pretty false tsconfig.build.json",
    "test": "pnpm build && pnpm -r test",
    "guard:merge-markers": "node ./scripts/guard-merge-markers.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
